{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Switch2svg",
  "version": "1.6.0",
  "identifier": "com.switch2svg.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "APP图标治理工具",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset: http://asset.localhost https://asset.localhost customprotocol:",
        "connect-src": "ipc: http://ipc.localhost https: http: ws: wss: blob: data: http://asset.localhost https://asset.localhost",
        "font-src": ["https://fonts.gstatic.com"],
        "img-src": "'self' asset: http://asset.localhost https://asset.localhost blob: data: https: http:",
        "style-src": "'unsafe-inline' 'self' https://fonts.googleapis.com"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
